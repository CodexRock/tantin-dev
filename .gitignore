# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/
node_modules/
functions/lib/

# Build-runner generated code (regenerated by CI before analyze/test).
# See .agent/DECISIONS.md (D004). NOTE: l10n outputs under lib/l10n/ are
# intentionally NOT ignored — they are committed for IDE/analysis ergonomics.
*.g.dart
*.freezed.dart

# Golden-test failure artifacts (only created when a golden FAILS — never commit
# them; the gate also hard-fails if any appear). Alchemist platform goldens are
# local-only; CI goldens under test/goldens/ci/ ARE committed.
test/**/failures/
test/goldens/macos/
test/goldens/linux/
test/goldens/windows/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
